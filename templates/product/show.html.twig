{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
    <div class="container">
    <h1>Product</h1>
        {% include 'layouts/_flash_message.html.twig' %}

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ product.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ product.Name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ product.Description }}</td>
            </tr>
            <tr>
                <th>SubCategory</th>
                <td>
                    {% for subCategory in product.SubCategory %}
                        {{ subCategory.Name }}<br>
                    {% endfor %}
                </td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ product.Price }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_product_index') }}" class="btn btn-secondary">back to list</a>

    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-outline-primary">edit</a>

    {{ include('product/_delete_form.html.twig') }}
    </div>
{% endblock %}
