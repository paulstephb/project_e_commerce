{% extends 'base.html.twig' %}

{% block title %}Category{% endblock %}

{% block body %}
<div class="container" style="margin-top: 50px;">
    <h1>Category</h1>
    {% include 'layouts/_flash_message.html.twig' %}
        <table class="table table-striped" style="margin-top: 20px;" >
            <tr>
                <th>Name</th>
                <th>Actions</th>
            </tr>
            {% for category in categories %}
                <tr>
                    <td>
                        {{ category.name }}
                    </td>
                    <td>
                        <a href="{{ path('app_category_update', {'id': category.id}) }}" class="btn btn-primary">Update</a>
                        <a href="{{ path('app_category_delete', {'id': category.id}) }}" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            {% else %}
                <p>No categories found</p>
            {% endfor %}
        </table>
        <a href="{{ path('app_category_new') }}" class="btn btn-success">Create New Category</a>
</div>
{% endblock %}